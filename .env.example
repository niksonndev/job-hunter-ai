OPENAI_API_KEY=coloque_sua_chave_aqui
DEFAULT_SEARCH_LIMIT=20
MAX_SEARCH_RESULTS=1000

# LinkedIn (opcional — se preenchido, faz login para obter mais resultados)
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

# Indeed (opcional — se preenchido, faz login para contornar Cloudflare)
# Crie uma conta gratuita em https://br.indeed.com e preencha abaixo
INDEED_EMAIL=
INDEED_PASSWORD=

# CapSolver (opcional — para bypass automático de CAPTCHA no login do LinkedIn/Indeed)
# Crie uma conta em https://dashboard.capsolver.com/ e copie sua API key
CAPSOLVER_API_KEY=
