OPENAI_API_KEY=coloque_sua_chave_aqui
DEFAULT_SEARCH_LIMIT=20
MAX_SEARCH_RESULTS=1000

# LinkedIn (optional — if set, logs in to get more results)
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

# Google Sheets (optional — if set, appends each processed job to a spreadsheet)
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_WORKSHEET_NAME=jobs
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# PRODUCTION OPTIMIZATIONS (new)
# Cache analysis results to reduce OpenAI costs by 30-50%
CACHE_ANALYSIS=true

# Concurrency limit for job processing (higher = faster but more LinkedIn/API load)
# Default: 2 (safe), Recommended: 2-3
JOB_CONCURRENCY=2

# Custom resume path (default: data/nikson-curriculo-generic.md)
RESUME_PATH=
